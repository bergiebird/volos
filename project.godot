; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="volos"
run/main_scene="res://addons/_ToyBox/Menus/Scenes/Opening/opening_with_logo.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
boot_splash/bg_color=Color(0.06, 0.06, 0.06, 1)
config/icon="res://V_icon.png"

[audio]

buses/default_bus_layout="res://ProjectVolos/Aniruth/INBOX/AudioBus_ProjectVolo.tres"

[autoload]

AppConfig="*res://addons/_ToyBox/Utility/Autoloads/AppConfig/app_config.gd"
SignalTown="*res://addons/_ToyBox/Utility/Autoloads/BergieWhereDoYouWantThese/SignalTown.gd"
PhantomCameraManager="*res://addons/phantom_camera/scripts/managers/phantom_camera_manager.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
ProjectUISoundController="*res://addons/_ToyBox/Utility/Autoloads/AudioControl/project_ui_sound_controller.tscn"
ProjectMusicController="*res://addons/_ToyBox/Utility/Autoloads/AudioControl/project_music_controller.tscn"
DiceWizard="*res://addons/_ToyBox/Utility/Autoloads/AutoWizards/dice_wizard.gd"
TimeWizard="*res://addons/_ToyBox/Utility/Autoloads/AutoWizards/time_wizard.gd"
SceneLoader="*res://addons/_ToyBox/Utility/Autoloads/SceneLoader/scene_loader.tscn"
GitReminder="*res://addons/_ToyBox/Utility/Autoloads/Tools/git_reminder.gd"
Taken="*res://addons/_ToyBox/Utility/Autoloads/BergieWhereDoYouWantThese/taken.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=480
window/size/always_on_top=true
window/size/window_width_override=640
window/size/window_height_override=480
window/stretch/mode="viewport"

[editor]

naming/script_name_casing=2

[editor_plugins]

enabled=PackedStringArray("res://addons/Todo_Manager/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

[file_customization]

folder_colors={
"res://ProjectVolos/": "red",
"res://addons/Todo_Manager/": "gray",
"res://addons/_ToyBox/": "red",
"res://addons/_ToyBox/Menus/": "blue",
"res://addons/dialogue_manager/": "gray",
"res://addons/input-overlay/": "gray",
"res://addons/limboai/": "gray",
"res://addons/phantom_camera/": "gray"
}

[global_group]

Weakling=""
Strongling=""

[input]

up={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":87,"key_label":0,"unicode":119,"location":0,"echo":false,"script":null)
]
}
