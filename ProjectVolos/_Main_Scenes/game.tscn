theme_override_constants/shadow_offset_y = 5
theme_override_constants/shadow_offset_x = 5
theme_override_constants/line_separation = 4
theme_override_font_sizes/normal_font_size = 24
bbcode_enabled = true
text = "[hue][wave]Score: 0[/wave][/hue]"
fit_content = true
scroll_active = false
custom_effects = [SubResource("RichTextEffect_t2t0a")]

[node name="Lvl" type="Node2D" parent="."]
unique_name_in_owner = true
editor_description = "Keep all @icons node_2D

All level information can be found here, while above this node will handle the camera, music, character's stats, etch. Everything below here is what is in the particular level. So enemys, layout, and such. "
script = ExtResource("4_awf6f")

[node name="LevelContainer" type="Node2D" parent="Lvl"]
unique_name_in_owner = true
script = ExtResource("7_aqlwd")

